# ╔══════════════════════════════════════════════════════════════╗
# ║  Claude Agent Dispatch — Project Defaults                  ║
# ║  Copy to .sandbox-pal-dispatch/config.defaults.env (standalone)  ║
# ║  or ~/agent-infra/config.defaults.env (reference mode)     ║
# ║                                                            ║
# ║  ⚠  This file is COMMITTED to the repository.              ║
# ║     Do NOT put secrets, tokens, or credentials here.       ║
# ║     Use config.env for sensitive overrides (gitignored).   ║
# ║                                                            ║
# ║  ⚠  All assignments below use the ${VAR:-default} form so  ║
# ║     that workflow env: blocks and config.env overrides are ║
# ║     preserved. Plain `VAR=value` would overwrite them.     ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Required ─────────────────────────────────────────────────
# GitHub bot account username (the account that will comment, push, create PRs)
AGENT_BOT_USER="${AGENT_BOT_USER:-}"

# ── Optional (defaults shown) ────────────────────────────────
# Max Claude conversation turns per invocation
AGENT_MAX_TURNS="${AGENT_MAX_TURNS:-200}"

# Timeout in seconds before killing a stuck claude -p process
AGENT_TIMEOUT="${AGENT_TIMEOUT:-3600}"

# Circuit breaker: max bot comments per hour per issue
AGENT_CIRCUIT_BREAKER_LIMIT="${AGENT_CIRCUIT_BREAKER_LIMIT:-8}"

# Path to shared Claude memory file (optional, enhances agent context)
# AGENT_MEMORY_FILE="${AGENT_MEMORY_FILE:-}"

# Pre-PR test command (if set, tests must pass before PR creation)
# Examples:
# AGENT_TEST_COMMAND="${AGENT_TEST_COMMAND:-npm test}"
# AGENT_TEST_COMMAND="${AGENT_TEST_COMMAND:-pytest}"
# AGENT_TEST_COMMAND="${AGENT_TEST_COMMAND:-cargo test}"
# AGENT_TEST_COMMAND="${AGENT_TEST_COMMAND:-dotnet test}"

# ── Tool Permissions ─────────────────────────────────────────
# Claude tools allowed during triage/reply (read-only + Write for plan file)
AGENT_ALLOWED_TOOLS_TRIAGE="${AGENT_ALLOWED_TOOLS_TRIAGE:-Read,Write,Grep,Glob,Bash(echo:*),Bash(cat:*),Bash(ls:*),Bash(find:*)}"

# Claude tools allowed during implementation/review (read-write by default)
AGENT_ALLOWED_TOOLS_IMPLEMENT="${AGENT_ALLOWED_TOOLS_IMPLEMENT:-Read,Edit,Write,Grep,Glob,Bash(git add:*),Bash(git commit:*),Bash(git status),Bash(git diff:*),Bash(git log:*),Bash(ls:*),Bash(cat:*),Bash(grep:*),Bash(find:*),Bash(mkdir:*)}"

# Additional tools to append for project-specific needs
# Examples:
# AGENT_EXTRA_TOOLS="${AGENT_EXTRA_TOOLS:-Bash(npm:*),Bash(npx:*)}"
# AGENT_EXTRA_TOOLS="${AGENT_EXTRA_TOOLS:-Bash(cargo:*)}"
# AGENT_EXTRA_TOOLS="${AGENT_EXTRA_TOOLS:-Bash(dotnet:*)}"
# AGENT_EXTRA_TOOLS="${AGENT_EXTRA_TOOLS:-Bash(Godot:*),Bash(godot:*)}"

# ── Custom Prompts (optional, uses built-in defaults if unset) ──
# Point to your own prompt files to customize agent behavior
# AGENT_PROMPT_TRIAGE="${AGENT_PROMPT_TRIAGE:-/path/to/your/triage-prompt.md}"
# AGENT_PROMPT_IMPLEMENT="${AGENT_PROMPT_IMPLEMENT:-/path/to/your/implement-prompt.md}"
# AGENT_PROMPT_REPLY="${AGENT_PROMPT_REPLY:-/path/to/your/reply-prompt.md}"
# AGENT_PROMPT_REVIEW="${AGENT_PROMPT_REVIEW:-/path/to/your/review-prompt.md}"

# ── Adversarial Review Gates ─────────────────────────────────
# Pre-implementation plan review: fresh session checks plan against issue
# Set to "false" to disable
# AGENT_ADVERSARIAL_PLAN_REVIEW="${AGENT_ADVERSARIAL_PLAN_REVIEW:-true}"

# Post-implementation diff review: fresh session checks diff against issue/plan
# Set to "false" to disable
# AGENT_POST_IMPL_REVIEW="${AGENT_POST_IMPL_REVIEW:-true}"

# Max retries when post-impl review finds concerns (0 = no retries, escalate to human)
# AGENT_POST_IMPL_REVIEW_MAX_RETRIES="${AGENT_POST_IMPL_REVIEW_MAX_RETRIES:-1}"

# Custom prompt files for review gates (uses built-in defaults if unset)
# AGENT_PROMPT_ADVERSARIAL_PLAN="${AGENT_PROMPT_ADVERSARIAL_PLAN:-/path/to/your/adversarial-plan.md}"
# AGENT_PROMPT_POST_IMPL_REVIEW="${AGENT_PROMPT_POST_IMPL_REVIEW:-/path/to/your/post-impl-review.md}"
# AGENT_PROMPT_POST_IMPL_RETRY="${AGENT_PROMPT_POST_IMPL_RETRY:-/path/to/your/post-impl-retry.md}"

# ── Model Configuration ──────────────────────────────────────
# Claude model to use for all agent sessions (empty = use CLI default)
# AGENT_MODEL="${AGENT_MODEL:-}"

# Per-workflow model overrides. Empty falls back to AGENT_MODEL, then CLI default.
# Useful for picking a faster/cheaper model for read-only review phases while
# keeping a stronger model for implementation (or vice versa).
# AGENT_MODEL_TRIAGE="${AGENT_MODEL_TRIAGE:-}"           # triage, reply, validate
# AGENT_MODEL_IMPLEMENT="${AGENT_MODEL_IMPLEMENT:-}"         # implementation session
# AGENT_MODEL_REVIEW="${AGENT_MODEL_REVIEW:-}"            # PR review session
# AGENT_MODEL_ADVERSARIAL_PLAN="${AGENT_MODEL_ADVERSARIAL_PLAN:-}"  # pre-implementation plan review
# AGENT_MODEL_POST_IMPL_REVIEW="${AGENT_MODEL_POST_IMPL_REVIEW:-}"  # post-implementation diff review
# AGENT_MODEL_POST_IMPL_RETRY="${AGENT_MODEL_POST_IMPL_RETRY:-}"   # retry after post-impl review concerns

# ── Notifications ────────────────────────────────────────────
# Notification level: "all" (every milestone), "actionable" (default, events
# needing user response), "failures" (only failures)
# AGENT_NOTIFY_LEVEL="${AGENT_NOTIFY_LEVEL:-actionable}"

# Backend: comma-separated list of "webhook" (Discord webhook), "bot" (Discord
# bot), "slack" (Slack bot). Empty = notifications disabled.
# Examples:
#   AGENT_NOTIFY_BACKEND="${AGENT_NOTIFY_BACKEND:-webhook}"
#   AGENT_NOTIFY_BACKEND="${AGENT_NOTIFY_BACKEND:-bot,slack}"
# AGENT_NOTIFY_BACKEND="${AGENT_NOTIFY_BACKEND:-}"
